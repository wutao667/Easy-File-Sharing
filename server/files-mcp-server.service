[Unit]
Description=files.huaguo.site MCP server
After=network.target

[Service]
Type=simple
User=wutao
WorkingDirectory=/var/www/test.huaguo.site/server
Environment=NODE_ENV=production
Environment=FILES_MCP_HOST=127.0.0.1
Environment=FILES_MCP_PORT=3101
ExecStart=/usr/bin/node /var/www/test.huaguo.site/server/files-mcp-server.js
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
